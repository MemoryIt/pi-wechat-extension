{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true
  },
  "include": [
    "*.ts",
    "api/*.ts",
    "auth/*.ts",
    "cdn/*.ts",
    "media/*.ts",
    "storage/*.ts",
    "util/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
